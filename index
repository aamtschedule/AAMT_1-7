<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Naap Schedule</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@600;700&display=swap"
        rel="stylesheet">
    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #0d1b35;
            --header: #162040;
            --accent: #f0a500;
            --text: #e8f0ff;
            --muted: #8099cc;
            --grid: #1e3060;
            --cell: #132040;
            --card: #1a2e58;
            --radius: 16px;
        }

        html,
        body {
            width: 100%;
            height: 100%;
            overflow: hidden;
            background: transparent;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--text);
            display: flex;
            flex-direction: column;
            gap: 8px;
            background: transparent;
        }

        .widget {
            background: var(--bg);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            height: 100%;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6), inset 0 0 0 1px rgba(255, 255, 255, 0.07);
        }

        .widget-header {
            background: var(--header);
            padding: 10px 14px 8px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 2px solid var(--accent);
            flex-shrink: 0;
        }

        .header-left {
            display: flex;
            flex-direction: column;
            gap: 1px;
        }

        .schedule-title {
            font-size: 16px;
            font-weight: 800;
            color: var(--text);
            line-height: 1.1;
        }

        .schedule-subtitle {
            font-size: 10px;
            color: var(--muted);
            margin-bottom: 6px;
        }

        .day-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: var(--accent);
        }

        .date-label {
            font-size: 18px;
            font-weight: 800;
            color: var(--text);
            letter-spacing: -0.3px;
            line-height: 1.1;
        }

        .time-now {
            font-family: 'JetBrains Mono', monospace;
            font-size: 13px;
            font-weight: 600;
            color: var(--muted);
            text-align: right;
        }

        .time-now .time-main {
            font-size: 15px;
            color: var(--text);
            display: block;
        }

        .time-now .time-secs {
            font-size: 11px;
            color: var(--muted);
            display: block;
            margin-top: 1px;
        }

        .next-badge {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            background: rgba(240, 165, 0, 0.15);
            color: var(--accent);
            border: 1px solid rgba(240, 165, 0, 0.3);
            border-radius: 4px;
            padding: 2px 5px;
            margin-top: 3px;
            display: inline-block;
        }

        .current-banner {
            margin: 10px 10px 0;
            border-radius: 10px;
            padding: 10px 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
            position: relative;
            overflow: hidden;
        }

        .current-banner::before {
            content: '';
            position: absolute;
            inset: 0;
            background: currentColor;
            opacity: 0.12;
        }

        .current-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
            animation: pulse 1.8s ease-in-out infinite;
        }

        @keyframes pulse {

            0%,
            100% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: 0.5;
                transform: scale(0.75);
            }
        }

        .current-info {
            flex: 1;
            min-width: 0;
        }

        .current-tag {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            opacity: 0.7;
            margin-bottom: 2px;
        }

        .current-id {
            font-family: 'JetBrains Mono', monospace;
            font-size: 15px;
            font-weight: 700;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .current-desc {
            font-size: 11px;
            font-weight: 500;
            opacity: 0.75;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .current-time {
            font-size: 10px;
            font-weight: 600;
            opacity: 0.6;
            text-align: right;
            flex-shrink: 0;
            line-height: 1.5;
        }

        .progress-bar-wrap {
            margin: 6px 10px 0;
            height: 3px;
            background: rgba(255, 255, 255, 0.06);
            border-radius: 3px;
            overflow: hidden;
            flex-shrink: 0;
        }

        .progress-bar {
            height: 100%;
            border-radius: 3px;
            transition: width 0.5s ease;
        }

        .classes-label {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: var(--muted);
            padding: 8px 12px 4px;
            flex-shrink: 0;
        }

        .classes-list {
            flex: 1;
            overflow-y: auto;
            padding: 0 10px 10px;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .classes-list::-webkit-scrollbar {
            display: none;
        }

        .class-card {
            display: flex;
            align-items: stretch;
            gap: 0;
            border-radius: 10px;
            overflow: hidden;
            background: var(--card);
            border: 1px solid rgba(255, 255, 255, 0.06);
            flex-shrink: 0;
            transition: opacity 0.2s;
        }

        .class-card.past {
            opacity: 0.38;
        }

        .class-card.now {
            border-color: rgba(255, 255, 255, 0.15);
            box-shadow: 0 0 0 1px var(--color) inset;
        }

        .card-bar {
            width: 4px;
            flex-shrink: 0;
        }

        .card-body {
            flex: 1;
            padding: 8px 10px;
            min-width: 0;
        }

        .card-top {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            gap: 6px;
            margin-bottom: 2px;
        }

        .card-id {
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
            font-weight: 700;
            white-space: nowrap;
        }

        .card-time {
            font-size: 10px;
            font-weight: 500;
            color: var(--muted);
            white-space: nowrap;
            flex-shrink: 0;
        }

        .card-desc {
            font-size: 11px;
            font-weight: 500;
            color: var(--text);
            opacity: 0.75;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .card-meta {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-top: 3px;
        }

        .card-room {
            font-size: 10px;
            color: var(--muted);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .card-dur {
            font-size: 9px;
            font-weight: 600;
            letter-spacing: 0.3px;
            opacity: 0.5;
            flex-shrink: 0;
            margin-left: auto;
        }

        .empty-state {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 6px;
            color: var(--muted);
            padding: 20px;
            text-align: center;
        }

        .empty-state .icon {
            font-size: 28px;
            opacity: 0.4;
        }

        .empty-state .msg {
            font-size: 12px;
            font-weight: 500;
            opacity: 0.6;
        }

        .empty-state .sub {
            font-size: 10px;
            opacity: 0.35;
        }

        .widget-footer {
            padding: 6px 12px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            flex-shrink: 0;
        }

        .footer-title {
            font-size: 9px;
            font-weight: 600;
            color: var(--muted);
            opacity: 0.5;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 60%;
        }

        .reload-btn {
            background: none;
            border: none;
            font-size: 10px;
            color: var(--muted);
            opacity: 0.4;
            cursor: pointer;
            padding: 2px 4px;
            font-family: 'Inter', sans-serif;
        }

        .reload-btn:active {
            opacity: 0.8;
        }

        .week-grid-wrap {
            padding: 8px 10px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            flex-shrink: 0;
        }

        .week-grid-title {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 6px;
        }

        .week-grid-scroll {
            position: relative;
            max-height: 190px;
            overflow-y: auto;
            overflow-x: hidden;
            border-radius: 8px;
            scroll-behavior: smooth;
        }

        .week-grid-scroll::-webkit-scrollbar {
            width: 4px;
        }

        .week-grid-scroll::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.15);
            border-radius: 4px;
        }

        .week-grid {
            position: relative;
            display: grid;
            grid-template-columns: 60px repeat(5, 1fr);
            grid-template-rows: 20px repeat(24, 16px);
            gap: 2px;
            font-size: 8px;
        }

        .grid-cell {
            border-radius: 3px;
            background: rgba(255, 255, 255, 0.04);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--muted);
        }

        .grid-head {
            font-weight: 700;
            background: rgba(255, 255, 255, 0.08);
        }

        .grid-time {
            font-size: 7px;
            justify-content: flex-start;
            padding-left: 4px;
            white-space: nowrap;
            transition: color 0.2s;
        }

        .grid-time.now-time {
            color: var(--accent);
            font-weight: 700;
        }

        .grid-class {
            color: white;
            font-size: 7px;
            font-weight: 700;
            line-height: 1.25;
            text-align: center;
            overflow: hidden;
            padding: 1px 2px;
        }

        .grid-today.grid-head {
            background: rgba(240, 165, 0, 0.2);
            color: var(--accent);
            outline: 1px solid var(--accent);
        }

        .grid-cell.grid-today:not(.grid-class):not(.grid-head) {
            background: rgba(240, 165, 0, 0.07);
        }

        .grid-class.grid-today {
            box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.35) inset;
            filter: saturate(1.15);
        }

        .grid-class.now-block {
            box-shadow: 0 0 0 1.5px #fff inset, 0 0 6px rgba(255, 255, 255, 0.55);
            animation: nowPulse 1.6s ease-in-out infinite;
            z-index: 2;
        }

        @keyframes nowPulse {

            0%,
            100% {
                filter: brightness(1) saturate(1.15);
            }

            50% {
                filter: brightness(1.3) saturate(1.3);
            }
        }

        .now-line {
            position: absolute;
            left: 0;
            right: 0;
            height: 0;
            border-top: 1.5px dashed var(--accent);
            z-index: 5;
            pointer-events: none;
            display: none;
        }
    </style>
</head>

<body>

    <div class="widget" id="widget">

        <div class="widget-header">
            <div class="header-left">
                <div class="schedule-title" id="scheduleTitle"></div>
                <div class="schedule-subtitle" id="scheduleSubtitle"></div>

                <div class="day-label" id="hdrDay"></div>
                <div class="date-label" id="hdrDate"></div>
                <div id="hdrBadge"></div>
            </div>
            <div class="time-now" id="hdrTime">
                <span class="time-main" id="timeMain"></span>
                <span class="time-secs" id="timeSecs"></span>
            </div>
        </div>

        <div id="currentWrap"></div>

        <div class="classes-label" id="listLabel">Today's Classes</div>
        <div class="classes-list" id="classesList"></div>

        <div class="week-grid-wrap">
            <div class="week-grid-title">Weekly Timetable</div>
            <div class="week-grid-scroll" id="weekGridScroll">
                <div id="weekGrid" class="week-grid"></div>
            </div>
        </div>

        <div class="widget-footer">
            <div class="footer-title" id="footerTitle"></div>
            <button class="reload-btn" onclick="manualRefresh()">â†» refresh</button>
        </div>

    </div>

    <script>
        const scheduleData = {
