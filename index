                { "id": "AMT1106", "desc": "Maintenance Forms and Publications", "room": "303b", "color": "#3a7bd5", "days": ["Wed"], "startH": 7, "startM": 0, "endH": 8, "endM": 0 },
                { "id": "AMT1106", "desc": "Maintenance Forms and Publications", "room": "Simulation Lab", "color": "#3a7bd5", "days": ["Thu"], "startH": 10, "startM": 0, "endH": 13, "endM": 0 },
                { "id": "AMT1106", "desc": "Maintenance Forms and Publications", "room": "303b", "color": "#3a7bd5", "days": ["Fri"], "startH": 7, "startM": 0, "endH": 8, "endM": 0 },
                { "id": "PATHFIT1", "desc": "Movement Competency Training", "room": "Covered Court", "color": "#ffc107", "days": ["Tue"], "startH": 14, "startM": 30, "endH": 16, "endM": 30 },
                { "id": "GEC1106", "desc": "Mathematics in the Modern World", "room": "303b", "color": "#4caf50", "days": ["Mon"], "startH": 9, "startM": 0, "endH": 10, "endM": 0 },
                { "id": "GEC1106", "desc": "Mathematics in the Modern World", "room": "303b", "color": "#4caf50", "days": ["Wed"], "startH": 9, "startM": 0, "endH": 10, "endM": 0 },
                { "id": "GEC1106", "desc": "Mathematics in the Modern World", "room": "303b", "color": "#4caf50", "days": ["Fri"], "startH": 9, "startM": 0, "endH": 10, "endM": 0 },
                { "id": "DRAW1101", "desc": "Aircraft Drawing", "room": "DR2", "color": "#2ec27e", "days": ["Mon"], "startH": 10, "startM": 0, "endH": 13, "endM": 0 },
                { "id": "AMT1101", "desc": "Aviation Safety", "room": "303b", "color": "#00bcd4", "days": ["Mon"], "startH": 8, "startM": 0, "endH": 9, "endM": 0 },
                { "id": "AMT1101", "desc": "Aviation Safety", "room": "303b", "color": "#00bcd4", "days": ["Wed"], "startH": 8, "startM": 0, "endH": 9, "endM": 0 },
                { "id": "AMT1102", "desc": "Aircraft Flight Control", "room": "303b", "color": "#ff5722", "days": ["Tue"], "startH": 8, "startM": 30, "endH": 11, "endM": 30 },
                { "id": "AMT1102", "desc": "Aircraft Flight Control", "room": "Hangar Table 1", "color": "#ff5722", "days": ["Fri"], "startH": 8, "startM": 0, "endH": 9, "endM": 0 },
                { "id": "AMT1103", "desc": "Aircraft Propeller", "room": "PP LAB", "color": "#9c6ade", "days": ["Wed"], "startH": 10, "startM": 0, "endH": 13, "endM": 0 },
                { "id": "AMT1103", "desc": "Aircraft Propeller", "room": "303b", "color": "#9c6ade", "days": ["Fri"], "startH": 10, "startM": 0, "endH": 11, "endM": 0 },
                { "id": "AMT1104", "desc": "Aircraft Handtools and Equipment", "room": "Fabrication Lab 2", "color": "#e8702a", "days": ["Thu"], "startH": 13, "startM": 0, "endH": 16, "endM": 0 },
                { "id": "AMT1104", "desc": "Aircraft Handtools and Equipment", "room": "303b", "color": "#e8702a", "days": ["Fri"], "startH": 11, "startM": 0, "endH": 12, "endM": 0 },
                { "id": "AMT1105", "desc": "Aircraft Powerplant 1", "room": "PP Lab 1", "color": "#e05a9a", "days": ["Mon"], "startH": 14, "startM": 0, "endH": 15, "endM": 30 },
                { "id": "AMT1105", "desc": "Aircraft Powerplant 1", "room": "303b", "color": "#e05a9a", "days": ["Tue"], "startH": 7, "startM": 0, "endH": 8, "endM": 30 },
                { "id": "AMT1105", "desc": "Aircraft Powerplant 1", "room": "PP Lab 1", "color": "#e05a9a", "days": ["Wed"], "startH": 14, "startM": 0, "endH": 18, "endM": 30 }
            ]
        }

        const DAY_MAP = { 0: 'Sun', 1: 'Mon', 2: 'Tue', 3: 'Wed', 4: 'Thu', 5: 'Fri', 6: 'Sat' }
        const DAY_FULL = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday']
        const MONTH = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec']

        function toMins(h, m) { return h * 60 + m }

        function fmt12(h, m) {
            const ampm = h < 12 ? 'AM' : 'PM'
            const h12 = h % 12 === 0 ? 12 : h % 12
            return `${h12}:${String(m).padStart(2, '0')} ${ampm}`
        }

        function durStr(startH, startM, endH, endM) {
            const mins = toMins(endH, endM) - toMins(startH, startM)
            const h = Math.floor(mins / 60), m = mins % 60
            return h > 0 ? (m > 0 ? `${h}h ${m}m` : `${h}h`) : `${m}m`
        }

        function minsToWords(totalMins) {
            totalMins = Math.max(0, Math.round(totalMins))
            const h = Math.floor(totalMins / 60)
            const m = totalMins % 60
            const hPart = h > 0 ? `${h} hour${h !== 1 ? 's' : ''}` : ''
            const mPart = m > 0 ? `${m} minute${m !== 1 ? 's' : ''}` : ''
            if (h > 0 && m > 0) return `${hPart} and ${mPart}`
            if (h > 0) return hPart
            return mPart || '0 minutes'
        }

        function esc(str) {
            return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        }

        function updateClock() {
            const now = new Date();
            const h = now.getHours();
            const m = now.getMinutes();
            const s = now.getSeconds();

            const ampm = h < 12 ? "AM" : "PM";
            const h12 = h % 12 === 0 ? 12 : h % 12;

            document.getElementById("timeMain").textContent =
                `${h12}:${String(m).padStart(2, "0")}:${String(s).padStart(2, "0")} ${ampm}`;
        }

        function renderWeekGrid() {
            const grid = document.getElementById('weekGrid')

            const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri']
            const today = DAY_MAP[new Date().getDay()]

            // Grid covers 7:00 AM to 19:00 (7 PM) in 30-min slots = 24 slots
            const slots = []
            for (let h = 7; h <= 18; h++) {
                slots.push({ h, m: 0 })
                slots.push({ h, m: 30 })
            }

            let html = ''

            html += `<div class="grid-cell grid-head" style="grid-row:1;grid-column:1"></div>`
            days.forEach((day, dIdx) => {
                const isToday = day === today
                html += `<div class="grid-cell grid-head ${isToday ? 'grid-today' : ''}" style="grid-row:1;grid-column:${dIdx + 2}">${day}</div>`
            })

            slots.forEach((slot, sIdx) => {
                html += `<div class="grid-cell grid-time" data-slot="${sIdx}" style="grid-row:${sIdx + 2};grid-column:1">${fmt12(slot.h, slot.m)}</div>`
            })

            days.forEach((day, dIdx) => {
                const isToday = day === today
                const covered = new Array(slots.length).fill(false)

                const dayCourses = scheduleData.courses.filter(c => c.days.includes(day))

                dayCourses.forEach(c => {
                    const startMin = toMins(c.startH, c.startM)
                    const endMin = toMins(c.endH, c.endM)
                    const startSlot = Math.round((startMin - 420) / 30) // 7:00 = 420 mins
                    const span = Math.round((endMin - startMin) / 30)
                    if (startSlot < 0 || startSlot >= slots.length || span <= 0) return

                    const rowStart = startSlot + 2
                    const rowEnd = Math.min(rowStart + span, slots.length + 2)
                    for (let i = startSlot; i < startSlot + span && i < slots.length; i++) covered[i] = true

                    html += `
                    <div
                        class="grid-cell grid-class ${isToday ? 'grid-today' : ''}"
                        data-day="${day}"
                        data-start="${startMin}"
                        data-end="${endMin}"
                        style="grid-row:${rowStart} / ${rowEnd};grid-column:${dIdx + 2};background:${c.color}"
                        title="${esc(c.id)} - ${esc(c.desc)}">
                        ${esc(c.id)}
                    </div>`
                })

                slots.forEach((slot, sIdx) => {
                    if (covered[sIdx]) return
                    html += `<div class="grid-cell ${isToday ? 'grid-today' : ''}" style="grid-row:${sIdx + 2};grid-column:${dIdx + 2}"></div>`
                })
            })

            grid.innerHTML = html

            const line = document.createElement('div')
            line.id = 'nowLine'
            line.className = 'now-line'
            line.innerHTML = '<span class="now-dot"></span>'
            grid.appendChild(line)

            updateNowLine()
        }

        function updateNowLine() {
            const grid = document.getElementById('weekGrid')
            const line = document.getElementById('nowLine')
            if (!grid || !line) return

            const now = new Date()
            const today = DAY_MAP[now.getDay()]
            const nowM = toMins(now.getHours(), now.getMinutes())

            grid.querySelectorAll('.grid-class').forEach(el => {
                const isNow = el.dataset.day === today &&
                    nowM >= parseInt(el.dataset.start, 10) &&
                    nowM < parseInt(el.dataset.end, 10)
                el.classList.toggle('now-block', isNow)
            })

            grid.querySelectorAll('.grid-time').forEach(el => el.classList.remove('now-time'))

            const inRange = nowM >= 420 && nowM < 1140 // 7:00 AM to 7:00 PM
            if (!inRange) {
                line.style.display = 'none'
                return
            }

            const slotFloat = (nowM - 420) / 30
            const flooredIdx = Math.max(0, Math.min(23, Math.floor(slotFloat)))
            const frac = slotFloat - Math.floor(slotFloat)

            const cellEl = grid.querySelector(`.grid-time[data-slot="${flooredIdx}"]`)
            if (!cellEl) {
                line.style.display = 'none'
                return
            }
            cellEl.classList.add('now-time')

            const top = cellEl.offsetTop + frac * cellEl.offsetHeight
            line.style.top = `${top}px`
            line.style.display = 'block'
        }

        function scrollToNow(instant) {
            const wrap = document.getElementById('weekGridScroll')
            const grid = document.getElementById('weekGrid')
            if (!wrap || !grid) return

            const now = new Date()
            const nowM = toMins(now.getHours(), now.getMinutes())
            const clamped = Math.min(1139, Math.max(420, nowM))
            const slotIdx = Math.max(0, Math.min(23, Math.floor((clamped - 420) / 30)))

            const cellEl = grid.querySelector(`.grid-time[data-slot="${slotIdx}"]`)
            if (!cellEl) return

            const target = cellEl.offsetTop - (wrap.clientHeight / 2) + (cellEl.offsetHeight / 2)
            wrap.scrollTo({ top: Math.max(0, target), behavior: instant ? 'auto' : 'smooth' })
        }

        function manualRefresh() {
            refresh()
            renderWeekGrid()
            requestAnimationFrame(() => scrollToNow(false))
        }

        function refresh() {
            const now = new Date()
            const dow = now.getDay()
            const today = DAY_MAP[dow]
            const nowM = toMins(now.getHours(), now.getMinutes())

            document.getElementById('hdrDay').textContent = DAY_FULL[dow].toUpperCase()
            document.getElementById('hdrDate').textContent = `${MONTH[now.getMonth()]} ${now.getDate()}, ${now.getFullYear()}`

            document.getElementById('scheduleTitle').textContent = scheduleData.title || 'Schedule'
            document.getElementById('scheduleSubtitle').textContent = scheduleData.subtitle || ''

            const courses = (scheduleData.courses || [])
                .filter(c => c.days && c.days.includes(today))
                .sort((a, b) => toMins(a.startH, a.startM) - toMins(b.startH, b.startM))

            const current = courses.find(c => nowM >= toMins(c.startH, c.startM) && nowM < toMins(c.endH, c.endM))
            const upcoming = courses.find(c => toMins(c.startH, c.startM) > nowM)

            const badge = document.getElementById('hdrBadge')
            if (current) {
                badge.innerHTML = `<span class="next-badge" style="color:${current.color};background:${current.color}22;border-color:${current.color}55">â—Ź IN CLASS</span>`
            } else if (upcoming) {
                const minsUntil = toMins(upcoming.startH, upcoming.startM) - nowM
                const h2 = Math.floor(minsUntil / 60), m2 = minsUntil % 60
                const untilStr = h2 > 0 ? `${h2}h ${m2}m` : `${m2}m`
                badge.innerHTML = `<span class="next-badge">Next in ${untilStr}</span>`
            } else {
                badge.innerHTML = ''
            }

            const wrap = document.getElementById('currentWrap')
            if (current) {
                const startM2 = toMins(current.startH, current.startM)
                const endM2 = toMins(current.endH, current.endM)
                const totalDur = endM2 - startM2
                const elapsed = nowM - startM2
                const pct = Math.min(100, Math.max(0, (elapsed / totalDur) * 100))
                const minsLeft = endM2 - nowM

                wrap.innerHTML = `
      <div class="current-banner" style="color:${current.color};margin:10px 10px 0">
        <div class="current-dot" style="background:${current.color}"></div>
        <div class="current-info">
          <div class="current-tag" style="color:${current.color}">NOW Â· ${minsToWords(minsLeft)} left</div>
          <div class="current-id" style="color:${current.color}">${esc(current.id)} - ${esc(current.room)}</div>
          <div class="current-desc">${esc(current.desc)}</div>
        </div>
        <div class="current-time" style="color:${current.color}">
          ${fmt12(current.startH, current.startM)}<br>${fmt12(current.endH, current.endM)}
        </div>
      </div>
      <div class="progress-bar-wrap" style="margin:5px 10px 0">
        <div class="progress-bar" style="width:${pct}%;background:${current.color}"></div>
      </div>
    `
            } else {
                wrap.innerHTML = ''
            }

            const listLabel = document.getElementById('listLabel')
            const list = document.getElementById('classesList')

            if (courses.length === 0) {
                listLabel.style.display = 'none'
                list.innerHTML = `
      <div class="empty-state">
        <div class="icon">đźŽ‰</div>
        <div class="msg">No classes today!</div>
        <div class="sub">Enjoy your ${DAY_FULL[dow]}</div>
      </div>`
                return
            }

            listLabel.style.display = 'block'
            const remaining = courses.filter(c => toMins(c.endH, c.endM) > nowM)
            const past = courses.filter(c => toMins(c.endH, c.endM) <= nowM)
            const ordered = [...remaining, ...past]

            listLabel.textContent = remaining.length > 0
                ? `${remaining.length} class${remaining.length > 1 ? 'es' : ''} remaining`
                : 'All done for today âś“'

            list.innerHTML = ordered.map(c => {
                const isNow = current && c === current
                const isPast = toMins(c.endH, c.endM) <= nowM
                return `
      <div class="class-card ${isNow ? 'now' : ''} ${isPast ? 'past' : ''}" style="--color:${c.color}">
        <div class="card-bar" style="background:${c.color}"></div>
        <div class="card-body">
          <div class="card-top">
            <div class="card-id" style="color:${c.color}">${esc(c.id)}</div>
            <div class="card-time">${fmt12(c.startH, c.startM)} â€“ ${fmt12(c.endH, c.endM)}</div>
          </div>
          <div class="card-desc">${esc(c.desc)}</div>
          <div class="card-meta">
            <div class="card-room">đź“Ť ${esc(c.room)}</div>
            <div class="card-dur">${durStr(c.startH, c.startM, c.endH, c.endM)}</div>
          </div>
        </div>
      </div>`
            }).join('')

            document.getElementById('footerTitle').textContent = scheduleData.title || 'Schedule'
        }

        updateClock()
        setInterval(updateClock, 1000)

        let lastRenderedDay = null

        function tick() {
            refresh()

            const today = DAY_MAP[new Date().getDay()]
            if (today !== lastRenderedDay) {
                lastRenderedDay = today
                renderWeekGrid()
                requestAnimationFrame(() => scrollToNow(true))
            } else {
                updateNowLine()
            }
        }

        refresh()
        renderWeekGrid()
        lastRenderedDay = DAY_MAP[new Date().getDay()]
        requestAnimationFrame(() => scrollToNow(true))

        setInterval(tick, 1000)

        document.addEventListener('visibilitychange', () => {
            if (document.visibilityState === 'visible') tick()
        })
        window.addEventListener('focus', () => tick())
    </script>
</body>

</html>
